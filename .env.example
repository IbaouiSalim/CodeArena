# CodeArena Environment Variables
# Copy this file to .env.prod for production deployment

# ═══════════════════════════════════════════════════════════════════════════════
# PRODUCTION DEPLOYMENT
# ═══════════════════════════════════════════════════════════════════════════════

# Domain name for the CodeArena instance (for TLS certificate)
# Example: codearena.example.com
DOMAIN=codearena.example.com

# Email for Let's Encrypt certificate registration
# Used for renewal notifications and account recovery
# Example: admin@example.com
ACME_EMAIL=admin@example.com


# ═══════════════════════════════════════════════════════════════════════════════
# CORS CONFIGURATION (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Allowed origin for CORS requests
# If not set, defaults to http://localhost:5173 (dev) or DOMAIN (production)
# CORS_ORIGIN=https://example.com


# ═══════════════════════════════════════════════════════════════════════════════
# DATABASE (Optional)
# ═══════════════════════════════════════════════════════════════════════════════

# Path to SQLite database file (inside container)
# Default: /app/data/codearena.db
# CODEARENA_DB_PATH=/app/data/codearena.db
